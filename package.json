{
  "name": "ecommerce-backend",
  "version": "1.0.0",
  "description": "Production-ready starter backend for ecommerce platform",
  "main": "./dist/server.js",
  "exports": "./dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "clean": "rimraf dist",
    "build": "npm run clean && tsup src/server.ts --format esm --out-dir dist",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:format": "prisma format",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:db:push": "prisma db push",
    "admin:seed": "tsx src/scripts/seedAdmin.ts",
    "storefront:seed": "node --import tsx src/scripts/seedStorefrontDemo.ts",
    "admin:catalog:seed:unsplash": "node --import tsx src/scripts/seedAdminPanelUnsplash.ts"
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "keywords": [
    "ecommerce",
    "backend",
    "express",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@prisma/client": "^6.14.0",
    "bcryptjs": "^3.0.3",
    "bwip-js": "^4.10.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "sanitize-html": "^2.17.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bwip-js": "^3.2.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/sanitize-html": "^2.16.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.2",
    "prisma": "^6.14.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2"
  }
}
