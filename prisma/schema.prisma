generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FlashSaleDiscountType {
  PERCENT
  TAKA
}

model Admin {
  id            String              @id @default(cuid())
  email         String              @unique
  password      String
  isActive      Boolean             @default(true)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  refreshTokens AdminRefreshToken[]

  @@map("admins")
}

model AdminRefreshToken {
  id         String    @id @default(cuid())
  adminId    String
  sessionId  String    @unique
  tokenHash  String    @unique
  expiresAt  DateTime
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  admin Admin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("admin_refresh_tokens")
}

model Category {
  id                        String                         @id @default(cuid())
  title                     String                         @unique
  slug                      String?                        @unique
  imageUrl                  String
  imagePath                 String
  subCategories             SubCategory[]
  products                  Product[]
  banners                   Banner[]
  freeDeliveryCampaignItems FreeDeliveryCampaignCategory[]
  topCatalogItems           TopCatalogCategory[]
  trendingCampaignItems     TrendingCampaignCategory[]
  categoryBanners           CategoryBanner[]
  createdAt                 DateTime                       @default(now())
  updatedAt                 DateTime                       @updatedAt

  @@map("categories")
}

model TopCatalogCategory {
  id         String   @id @default(cuid())
  categoryId String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@map("top_catalog_categories")
}

model SubCategory {
  id                        String                            @id @default(cuid())
  categoryId                String
  title                     String
  slug                      String?                           @unique
  imageUrl                  String
  imagePath                 String
  products                  Product[]
  freeDeliveryCampaignItems FreeDeliveryCampaignSubCategory[]
  trendingCampaignItems     TrendingCampaignSubCategory[]
  createdAt                 DateTime                          @default(now())
  updatedAt                 DateTime                          @updatedAt

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, title])
  @@map("sub_categories")
}

model Product {
  id                    String   @id @default(cuid())
  slugId                Int      @unique @default(autoincrement())
  categoryId            String
  subCategoryId         String
  title                 String
  slug                  String   @unique
  brand                 String?
  descriptionDelta      Json
  descriptionHtml       String
  extraDescriptionDelta Json?
  extraDescriptionHtml  String?
  weight                String
  material              String?
  rating                Float?
  stock                 Boolean  @default(true)
  availability          Boolean  @default(true)
  isFreeDelivery        Boolean  @default(false)
  isTrending            Boolean  @default(false)
  videoUrl              String?
  videoPath             String?
  variantLabel          String?  @default("Size")
  specifications        Json?    @default("[]")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  category                  Category                              @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  subCategory               SubCategory                           @relation(fields: [subCategoryId], references: [id], onDelete: Cascade)
  variants                  ProductVariant[]
  flashSaleItems            FlashSaleProduct[]
  freeDeliveryCampaignItems FreeDeliveryCampaignProduct[]
  freeDeliveryExclusions    FreeDeliveryCampaignExcludedProduct[]
  trendingCampaignItems     TrendingCampaignProduct[]
  trendingExclusions        TrendingCampaignExcludedProduct[]
  orderItems                OrderItem[]
  landingPages              LandingPage[]

  @@index([categoryId])
  @@index([subCategoryId])
  @@index([isFreeDelivery])
  @@index([isTrending])
  @@map("products")
}

model FreeDeliveryCampaign {
  id               String                                @id @default(cuid())
  singletonKey     String                                @unique @default("GLOBAL")
  title            String
  isActive         Boolean                               @default(true)
  categories       FreeDeliveryCampaignCategory[]
  subCategories    FreeDeliveryCampaignSubCategory[]
  products         FreeDeliveryCampaignProduct[]
  excludedProducts FreeDeliveryCampaignExcludedProduct[]
  createdAt        DateTime                              @default(now())
  updatedAt        DateTime                              @updatedAt

  @@map("free_delivery_campaigns")
}

model FreeDeliveryCampaignCategory {
  id                     String   @id @default(cuid())
  freeDeliveryCampaignId String
  categoryId             String
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  freeDeliveryCampaign FreeDeliveryCampaign @relation(fields: [freeDeliveryCampaignId], references: [id], onDelete: Cascade)
  category             Category             @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([freeDeliveryCampaignId, categoryId])
  @@index([freeDeliveryCampaignId])
  @@index([categoryId])
  @@map("free_delivery_campaign_categories")
}

model FreeDeliveryCampaignSubCategory {
  id                     String   @id @default(cuid())
  freeDeliveryCampaignId String
  subCategoryId          String
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  freeDeliveryCampaign FreeDeliveryCampaign @relation(fields: [freeDeliveryCampaignId], references: [id], onDelete: Cascade)
  subCategory          SubCategory          @relation(fields: [subCategoryId], references: [id], onDelete: Cascade)

  @@unique([freeDeliveryCampaignId, subCategoryId])
  @@index([freeDeliveryCampaignId])
  @@index([subCategoryId])
  @@map("free_delivery_campaign_sub_categories")
}

model FreeDeliveryCampaignProduct {
  id                     String   @id @default(cuid())
  freeDeliveryCampaignId String
  productId              String
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  freeDeliveryCampaign FreeDeliveryCampaign @relation(fields: [freeDeliveryCampaignId], references: [id], onDelete: Cascade)
  product              Product              @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([freeDeliveryCampaignId, productId])
  @@index([freeDeliveryCampaignId])
  @@index([productId])
  @@map("free_delivery_campaign_products")
}

model FreeDeliveryCampaignExcludedProduct {
  id                     String   @id @default(cuid())
  freeDeliveryCampaignId String
  productId              String
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  freeDeliveryCampaign FreeDeliveryCampaign @relation(fields: [freeDeliveryCampaignId], references: [id], onDelete: Cascade)
  product              Product              @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([freeDeliveryCampaignId, productId])
  @@index([freeDeliveryCampaignId])
  @@index([productId])
  @@map("free_delivery_campaign_excluded_products")
}

model ProductVariant {
  id              String   @id @default(cuid())
  productId       String
  actualPrice     Decimal  @db.Decimal(10, 2)
  discountedPrice Decimal  @db.Decimal(10, 2)
  color           String
  colorCode       String?
  size            String?
  imageUrl        String
  imagePath       String
  barcodeUrl      String?
  barcodePath     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_variants")
}

model Banner {
  id         String   @id @default(cuid())
  title      String
  subTitle   String?
  url        String
  categoryId String?
  inHomePage Boolean  @default(false)
  imageUrl   String
  imagePath  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([categoryId])
  @@index([inHomePage])
  @@map("banners")
}

model YoutubeVideo {
  id        String   @id @default(cuid())
  title     String
  url       String
  imageUrl  String
  imagePath String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("youtube_videos")
}

model FlashSaleCampaign {
  id            String                @id @default(cuid())
  title         String
  startAt       DateTime
  endAt         DateTime
  discountType  FlashSaleDiscountType
  discountValue Decimal               @db.Decimal(10, 2)
  bannerUrl     String?
  products      FlashSaleProduct[]
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([startAt])
  @@index([endAt])
  @@map("flash_sale_campaigns")
}

model FlashSaleProduct {
  id                  String   @id @default(cuid())
  flashSaleCampaignId String
  productId           String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  flashSaleCampaign FlashSaleCampaign @relation(fields: [flashSaleCampaignId], references: [id], onDelete: Cascade)
  product           Product           @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([flashSaleCampaignId, productId])
  @@index([flashSaleCampaignId])
  @@index([productId])
  @@map("flash_sale_products")
}

model TrendingCampaign {
  id               String                            @id @default(cuid())
  singletonKey     String                            @unique @default("GLOBAL")
  title            String
  isActive         Boolean                           @default(true)
  categories       TrendingCampaignCategory[]
  subCategories    TrendingCampaignSubCategory[]
  products         TrendingCampaignProduct[]
  excludedProducts TrendingCampaignExcludedProduct[]
  createdAt        DateTime                          @default(now())
  updatedAt        DateTime                          @updatedAt

  @@map("trending_campaigns")
}

model TrendingCampaignCategory {
  id                 String   @id @default(cuid())
  trendingCampaignId String
  categoryId         String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  trendingCampaign TrendingCampaign @relation(fields: [trendingCampaignId], references: [id], onDelete: Cascade)
  category         Category         @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([trendingCampaignId, categoryId])
  @@index([trendingCampaignId])
  @@index([categoryId])
  @@map("trending_campaign_categories")
}

model TrendingCampaignSubCategory {
  id                 String   @id @default(cuid())
  trendingCampaignId String
  subCategoryId      String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  trendingCampaign TrendingCampaign @relation(fields: [trendingCampaignId], references: [id], onDelete: Cascade)
  subCategory      SubCategory      @relation(fields: [subCategoryId], references: [id], onDelete: Cascade)

  @@unique([trendingCampaignId, subCategoryId])
  @@index([trendingCampaignId])
  @@index([subCategoryId])
  @@map("trending_campaign_sub_categories")
}

model TrendingCampaignProduct {
  id                 String   @id @default(cuid())
  trendingCampaignId String
  productId          String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  trendingCampaign TrendingCampaign @relation(fields: [trendingCampaignId], references: [id], onDelete: Cascade)
  product          Product          @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([trendingCampaignId, productId])
  @@index([trendingCampaignId])
  @@index([productId])
  @@map("trending_campaign_products")
}

model TrendingCampaignExcludedProduct {
  id                 String   @id @default(cuid())
  trendingCampaignId String
  productId          String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  trendingCampaign TrendingCampaign @relation(fields: [trendingCampaignId], references: [id], onDelete: Cascade)
  product          Product          @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([trendingCampaignId, productId])
  @@index([trendingCampaignId])
  @@index([productId])
  @@map("trending_campaign_excluded_products")
}

enum PromoDiscountType {
  AMOUNT
  PERCENT
}

model PromoCode {
  id            String            @id @default(cuid())
  code          String            @unique
  discountType  PromoDiscountType
  discountValue Decimal           @db.Decimal(10, 2)
  minOrderValue Decimal?          @db.Decimal(10, 2)
  maxDiscount   Decimal?          @db.Decimal(10, 2)
  startDate     DateTime?
  endDate       DateTime?
  isActive      Boolean           @default(true)
  usageCount    Int               @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([code])
  @@index([isActive])
  @@map("promo_codes")
}

enum OrderStatus {
  PENDING
  PROCESSING
  HOLD
  PICKUP
  DELIVERED
  CUSTOMER_CANCELLED
  CANCELLED
  TRASH
}

model Order {
  id   String @id @default(cuid())
  code String @unique

  customerName  String
  customerPhone String
  address       String
  district      String
  union         String?
  orderNotes    String? @db.Text

  subtotal       Decimal @db.Decimal(10, 2)
  shippingCharge Decimal @db.Decimal(10, 2)
  discountAmount Decimal @default(0) @db.Decimal(10, 2)
  total          Decimal @db.Decimal(10, 2)

  promoCode     String?
  consignmentId String?
  trackingCode  String?

  status OrderStatus @default(PENDING)

  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([status])
  @@index([customerPhone])
  @@map("orders")
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  productId String

  productName  String
  productImage String?
  price        Decimal @db.Decimal(10, 2)
  quantity     Int
  color        String?
  size         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model FooterConfig {
  id        String   @id @default("main")
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("footer_config")
}

model CategoryBanner {
  id         String   @id @default(cuid())
  title      String
  subTitle   String?
  url        String?
  categoryId String
  imageUrl   String
  imagePath  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@map("category_banners")
}

model LandingPage {
  id           String @id @default(cuid())
  slug         String @unique
  colorPalette String @default("blue")

  heroSection         Json?
  tableSection        Json?
  featureCards        Json?
  timerSection        Json?
  sliderSection       Json?
  videoSection        Json?
  bulletPointsSection Json?
  tipsSection         Json?
  checkoutSection     Json?
  faqSection          Json?
  whatsappSection     Json?

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("landing_pages")
}
